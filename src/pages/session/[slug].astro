---
import Header from '../../components/Header.astro';
import { getAllPosts } from '../../utils/posts';
import { getSpeakers } from '../../utils/speakers';

interface Props {
  params: { slug: string };
}

const { slug } = Astro.params;
const allPosts = getAllPosts();
const post = allPosts.find(p => p.slug === slug);

if (!post) {
  return Astro.redirect('/404');
}

const sessionLocale = post.locale as 'en' | 'fr';
const speakers = getSpeakers(sessionLocale);

function nameToImageFilename(name: string): string {
  return name
    .toLowerCase()
    .replace(/\s+/g, '_')
    .replace(/[éèê]/g, 'e')
    .replace(/[àâ]/g, 'a')
    .replace(/[ôö]/g, 'o')
    .replace(/[ç]/g, 'c');
}

function nameToSlug(name: string): string {
  return name
    .toLowerCase()
    .replace(/\s+/g, '-')
    .replace(/[éèê]/g, 'e')
    .replace(/[àâ]/g, 'a')
    .replace(/[ôö]/g, 'o')
    .replace(/[ç]/g, 'c');
}

const speakerIds = Array.isArray(post.metadata.speaker)
  ? post.metadata.speaker
  : post.metadata.speaker ? [post.metadata.speaker] : [];

const sessionSpeakers = speakerIds
  .map(speakerId => speakers.find(s => s.id === speakerId))
  .filter(Boolean);

export function getStaticPaths() {
  const allPosts = getAllPosts();
  return allPosts.map(post => ({
    params: { slug: post.slug },
  }));
}
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{post.metadata.title} - GenevaJUG</title>
    <link rel="icon" type="image/png" href="/apple_touch_icon.png" />
    <link rel="apple-touch-icon" href="/apple_touch_icon.png" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      :root[data-theme='light'] {
        --bg-primary: #ffffff;
        --bg-secondary: #f0f0f0;
        --text-primary: #000000;
        --text-secondary: #333333;
        --text-muted: #666666;
        --border-color: #e0e0e0;
      }

      :root[data-theme='dark'] {
        --bg-primary: #1a1a1a;
        --bg-secondary: #2a2a2a;
        --text-primary: #ffffff;
        --text-secondary: #cccccc;
        --text-muted: #999999;
        --border-color: #444444;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto,
          'Helvetica Neue', Arial, sans-serif;
        line-height: 1.6;
        background: var(--bg-primary);
        color: var(--text-secondary);
      }

      .container {
        max-width: 900px;
        margin: 0 auto;
        padding: 2rem;
      }

      .back-link {
        display: inline-block;
        margin-bottom: 2rem;
        color: #007bff;
        text-decoration: none;
        font-size: 0.95rem;
      }

      .back-link:hover {
        text-decoration: underline;
      }

      .session-detail {
        background: var(--bg-secondary);
        border: 1px solid var(--border-color);
        border-radius: 8px;
        padding: 2rem;
        margin-bottom: 2rem;
      }

      .session-detail h1 {
        font-size: 2rem;
        color: var(--text-primary);
        margin-bottom: 1rem;
      }

      .session-meta {
        display: flex;
        gap: 1.5rem;
        margin-bottom: 2rem;
        font-size: 0.95rem;
        color: var(--text-muted);
      }

      .session-content {
        margin-top: 2rem;
        line-height: 1.8;
      }

      .session-content p {
        margin-bottom: 1rem;
      }

      .speakers-section {
        margin-top: 3rem;
        padding-top: 2rem;
        border-top: 1px solid var(--border-color);
      }

      .speakers-section h2 {
        font-size: 1.5rem;
        color: var(--text-primary);
        margin-bottom: 1.5rem;
      }

      .speaker-link {
        text-decoration: none;
        color: inherit;
        transition: all 0.3s ease;
        display: block;
      }

      .speaker-link:hover .speaker-item {
        transform: translateX(4px);
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
      }

      :root[data-theme='dark'] .speaker-link:hover .speaker-item {
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
      }

      .speaker-item {
        display: flex;
        gap: 2rem;
        margin-bottom: 2rem;
        padding: 1.5rem;
        background: var(--bg-primary);
        border-radius: 8px;
        transition: all 0.3s ease;
      }

      .speaker-image {
        flex-shrink: 0;
      }

      .speaker-image img {
        width: 150px;
        height: 150px;
        object-fit: cover;
        border-radius: 8px;
      }

      .speaker-info h3 {
        font-size: 1.25rem;
        color: var(--text-primary);
        margin-bottom: 0.5rem;
      }

      .speaker-info p {
        font-size: 0.95rem;
        line-height: 1.6;
      }

      @media (max-width: 768px) {
        .container {
          padding: 1rem;
        }

        .session-detail {
          padding: 1.5rem;
        }

        .session-detail h1 {
          font-size: 1.5rem;
        }

        .session-meta {
          flex-direction: column;
          gap: 0.5rem;
        }

        .speaker-item {
          flex-direction: column;
          gap: 1rem;
        }

        .speaker-image img {
          width: 100px;
          height: 100px;
        }
      }
    </style>
  </head>
  <body>
    <Header locale={sessionLocale} />

    <div class="container">
      <a href={sessionLocale === 'en' ? '/#past-sessions' : '/fr#past-sessions'} class="back-link">
        {sessionLocale === 'en' ? '← Back to Past Sessions' : '← Retour aux sessions passées'}
      </a>

      <div class="session-detail">
        <h1>{post.metadata.title}</h1>

        <div class="session-meta">
          <span>📅 {post.metadata.date}</span>
        </div>

        <div class="session-content" set:html={post.content}></div>

        {sessionSpeakers.length > 0 && (
          <div class="speakers-section">
            <h2>
              {sessionLocale === 'en'
                ? sessionSpeakers.length === 1 ? 'Speaker' : 'Speakers'
                : sessionSpeakers.length === 1 ? 'Conférencier' : 'Conférenciers'}
            </h2>
            {sessionSpeakers.map((speaker) => (
              <a href={`/speaker/${speaker.id}`} class="speaker-link">
                <div class="speaker-item">
                  {speaker.image && (
                    <div class="speaker-image">
                      <img src={speaker.image} alt={speaker.name} />
                    </div>
                  )}
                  <div class="speaker-info">
                    <h3>{speaker.name}</h3>
                    {speaker.bio && <p>{speaker.bio}</p>}
                  </div>
                </div>
              </a>
            ))}
          </div>
        )}
      </div>
    </div>
  </body>
</html>
