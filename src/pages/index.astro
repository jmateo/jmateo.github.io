---
import Header from '../components/Header.astro';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>GenevaJUG</title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto,
          'Helvetica Neue', Arial, sans-serif;
        line-height: 1.6;
        background: #f5f5f5;
      }

      main {
        max-width: 800px;
        margin: 0 auto;
        padding: 2rem;
      }

      h1 {
        color: #333;
        border-bottom: 2px solid #007bff;
        padding-bottom: 0.5rem;
        margin-bottom: 1.5rem;
      }

      .info-box {
        background: white;
        border: 1px solid #ddd;
        border-radius: 4px;
        padding: 1.5rem;
        margin: 1.5rem 0;
      }

      .success {
        color: #28a745;
        font-weight: bold;
      }
    </style>
  </head>
  <body>
    <Header locale="en" />

    <main>
      <h1>Welcome to GenevaJUG Astro Migration</h1>

      <div class="info-box">
        <p class="success">✓ Astro is working!</p>
        <p>This is a dummy page created as the first step of migrating from Jekyll to Astro.</p>
      </div>

      <div class="info-box">
        <h2>Next Steps</h2>
        <ul>
          <li>Create Astro layouts for site structure</li>
          <li>Migrate existing content from Jekyll posts</li>
          <li>Set up collections for events, speakers, and sponsors</li>
          <li>Migrate styles and assets</li>
          <li>Deploy to GitHub Pages</li>
        </ul>
      </div>

      <div class="info-box">
        <h2>Project Info</h2>
        <p>
          <strong>Site:</strong> GenevaJUG (Java User Group)<br />
          <strong>Previous Setup:</strong> Jekyll + GitHub Pages<br />
          <strong>New Setup:</strong> Astro + GitHub Pages<br />
        </p>
      </div>
    </main>
  </body>
</html>
